PORT=3456
NODE_ENV=development

# Database — Docker (recommended): npm run docker:up
# Host tools (npm start, Workbench, db:check) MUST use DB_PORT=3307
# App container uses DB_HOST=mysql internally on port 3306
#
# Local MySQL 9.7 only: DB_PORT=3306, then npm run db:init (provisions daily_taaza user)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=daily_taaza
DB_PASSWORD=your_password_here
DB_NAME=daily_taaza
DB_DOCKER_PORT=3307
# DB_USE_MEMORY=true   # only for npm test

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_PHONE=919876543210

# Uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_MB=5
PRODUCT_MAX_IMAGES=10

# CORS
CORS_ORIGIN=*
