{
  "name": "daily-taaza",
  "version": "2.0.0",
  "description": "Daily Taaza — organic South Indian food e-commerce",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:check": "node scripts/db-check.js",
    "db:init": "node scripts/db-init.js",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:wait": "node scripts/wait-for-mysql.js",
    "db:setup": "npm run db:up && npm run db:wait && npm run db:seed",
    "db:provision": "node scripts/db-provision.js",
    "db:seed": "node sql/seed.js",
    "test": "node tests/api.test.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app mysql",
    "docker:seed": "docker compose exec app node sql/seed.js",
    "docker:test": "node tests/e2e.docker.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.11.0",
    "razorpay": "^2.9.6",
    "uuid": "^11.1.0"
  }
}
